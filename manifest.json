{
  "manifest_version": 3,
  "name": "AI Chat PDF Exporter",
  "version": "1.0.0",
  "description": "Export conversations from Claude, ChatGPT, Gemini, and Grok into beautifully formatted PDF documents.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://grok.com/*",
    "https://x.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://grok.com/*",
        "https://x.com/i/grok*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
